   <string notr="true">
QDialog {
    background-color: #1a1429;
    font-family: &quot;Microsoft YaHei&quot;;
    color: #f4e7c3;
    border: 2px solid #9f7a36;
    border-radius: 16px;
}

/* 标题 */
#titleLabel {
    font-size: 20px;
    font-weight: 700;
    color: #f8dd95;
    letter-spacing: 1px;
}

/* 进度条整体 */
QProgressBar {
    border: 2px solid #8e6a2b;
    border-radius: 11px;
    background-color: #2a1f3f;
    height: 24px;
    text-align: center;
    color: #f8e8bf;
    font-weight: 700;
}

/* 进度条块 */
QProgressBar::chunk {
    border-radius: 9px;
    background-color: qlineargradient(x1:0, y1:0, x2:1, y2:0,
                                      stop:0 #7f4bb6, stop:0.5 #b079e2, stop:1 #f1c46b);
    margin: 1px;
}

/* 按钮 */
QPushButton {
    background-color: #5f3e9b;
    color: #fff4d6;
    border: 1px solid #cba75e;
    padding: 8px 22px;
    border-radius: 10px;
    font-weight: 700;
}

QPushButton:hover {
    background-color: #7b56be;
    border: 1px solid #f1d28d;
}

QPushButton:pressed {
    background-color: #493173;
}
   </string>
