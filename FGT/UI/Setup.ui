  <property name="styleSheet">
   <string notr="true">QMainWindow, QWidget {
    background-color: #24233a;
    color: #f2f6ff;
    font-family: &quot;Microsoft YaHei&quot;;
    font-size: 13px;
}

QWidget#centralwidget {
    background-color: #24233a;
}

QFrame#headerFrame {
    background-color: #2a2942;
    border: 1px solid rgba(188, 201, 242, 0.34);
    border-radius: 12px;
}

QLabel#titleLabel {
    font-size: 24px;
    font-weight: 700;
    color: #ffffff;
}

QLabel#subtitleLabel {
    font-size: 14px;
    color: #bcc9f2;
}

QFrame#stepFrame, QFrame#contentFrame {
    background-color: #27263f;
    border: 1px solid rgba(188, 201, 242, 0.34);
    border-radius: 12px;
}

QLabel[class=&quot;stepLabel&quot;] {
    color: #f2f6ff;
    font-size: 13px;
}

QLabel#stepCurrent {
    color: #ffffff;
    font-weight: 700;
}

QProgressBar {
    border: 1px solid #6675a8;
    border-radius: 8px;
    text-align: center;
    background-color: #2f2d45;
    color: #e2e8ff;
}

QProgressBar::chunk {
    border-radius: 7px;
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0,
                                stop:0 #6f56ff, stop:1 #8f7bff);
}

QLineEdit {
    background-color: #2f2d45;
    border: 1px solid #6675a8;
    border-radius: 8px;
    padding: 6px 10px;
    color: #f2f6ff;
}

QCheckBox {
    color: #f2f6ff;
    spacing: 8px;
}

QPushButton {
    background-color: #4f46e5;
    color: #ffffff;
    border: none;
    border-radius: 9px;
    padding: 8px 16px;
    font-weight: 600;
}

QPushButton:hover {
    background-color: #5d54f0;
}

QPushButton:pressed {
    background-color: #443bc7;
}

QPushButton#cancelButton {
    background-color: #3a3854;
}

QPushButton#cancelButton:hover {
    background-color: #4a4866;
}</string>
