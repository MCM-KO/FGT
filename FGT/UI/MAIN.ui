}

QListWidget#LIST {
    background-color: #2f2d45;
    color: #e2e8ff;
    border: 1px solid #6675a8;
    border-radius: 12px;
    padding: 10px 8px;
    outline: 0;
}

QListWidget#LIST::item {
    background: transparent;
    border-radius: 10px;
    margin: 5px 2px;
    padding: 10px 14px;
}

QListWidget#LIST::item:selected {
    background-color: #4f46e5;
    color: #ffffff;
    font-weight: 600;
}

QListWidget#LIST::item:hover {
    background-color: #3a3854;
}

QStackedWidget {
    background-color: #2b2a42;
    border: 1px solid #6675a8;
    border-radius: 14px;
}

QScrollArea, QScrollArea QWidget {
    background: transparent;
    border: none;
}

QScrollBar:vertical {
    background: #221a35;
    width: 14px;
    margin: 2px;
    border: 1px solid #7f6330;
    border-radius: 7px;
}

QScrollBar::handle:vertical {
    min-height: 28px;
    border-radius: 6px;
    border: 1px solid #d5b16a;
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
                                stop:0 #7d4db7, stop:0.55 #a571d9, stop:1 #e4bf75);
}

QScrollBar::handle:vertical:hover {
    border: 1px solid #f0d79d;
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
                                stop:0 #9762cf, stop:0.55 #bb84ea, stop:1 #f3cf83);
}

QScrollBar::handle:vertical:pressed {
    background: #6a4598;
}

QScrollBar::add-line:vertical,
QScrollBar::sub-line:vertical {
    height: 0px;
    border: none;
    background: transparent;
}

QScrollBar::add-page:vertical,
QScrollBar::sub-page:vertical {
    background: transparent;
}

QScrollBar:horizontal {
    background: #221a35;
    height: 14px;
    margin: 2px;
    border: 1px solid #7f6330;
    border-radius: 7px;
}

QScrollBar::handle:horizontal {
    min-width: 28px;
    border-radius: 6px;
    border: 1px solid #d5b16a;
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0,
                                stop:0 #7d4db7, stop:0.55 #a571d9, stop:1 #e4bf75);
}

QScrollBar::handle:horizontal:hover {
    border: 1px solid #f0d79d;
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0,
                                stop:0 #9762cf, stop:0.55 #bb84ea, stop:1 #f3cf83);
}

QScrollBar::handle:horizontal:pressed {
    background: #6a4598;
}

QScrollBar::add-line:horizontal,
QScrollBar::sub-line:horizontal {
    width: 0px;
    border: none;
    background: transparent;
}

QScrollBar::add-page:horizontal,
QScrollBar::sub-page:horizontal {
    background: transparent;
}

QLabel {
    color: #f2f6ff;
    background-color: transparent;
    border: none;
    border-radius: 0px;
    padding: 0px;
    min-height: 0px;
}

QComboBox, QSpinBox, QDoubleSpinBox {
    background: #1f1d33;
    color: #f3f6ff;
    border: 1px solid rgba(188, 201, 242, 0.45);
    border-radius: 8px;
    padding: 4px 8px;
    min-height: 34px;
}

QSpinBox, QDoubleSpinBox {
    padding-right: 30px;
}

QComboBox:hover, QSpinBox:hover, QDoubleSpinBox:hover {
    border: 1px solid #8fa4e5;
    background: #23203a;
}

QComboBox:focus, QSpinBox:focus, QDoubleSpinBox:focus {
    border: 1px solid #9ed0ff;
    background: #25223d;
}

QComboBox::drop-down {
    subcontrol-origin: padding;
    subcontrol-position: top right;
    width: 30px;
    border-left: 1px solid rgba(188, 201, 242, 0.40);
    background-color: #323056;
    border-top-right-radius: 8px;
    border-bottom-right-radius: 8px;
}

QComboBox::down-arrow {
    width: 12px;
    height: 12px;
}

QComboBox QAbstractItemView {
    background-color: #2b2a42;
    color: #f2f6ff;
    border: 1px solid #6b7bb0;
    selection-background-color: #4f46e5;
}

QSpinBox::up-button, QSpinBox::down-button,
QDoubleSpinBox::up-button, QDoubleSpinBox::down-button {
    subcontrol-origin: border;
    width: 28px;
    background-color: #34325e;
    border-left: 1px solid rgba(188, 201, 242, 0.62);
}

QSpinBox::up-button, QDoubleSpinBox::up-button {
    subcontrol-position: top right;
    height: 17px;
    border-top-right-radius: 8px;
    border-bottom: 1px solid rgba(188, 201, 242, 0.35);
}

QSpinBox::down-button, QDoubleSpinBox::down-button {
    subcontrol-position: bottom right;
    height: 17px;
    border-bottom-right-radius: 8px;
}

QSpinBox::up-arrow, QSpinBox::down-arrow,
QDoubleSpinBox::up-arrow, QDoubleSpinBox::down-arrow {
    width: 14px;
    height: 14px;
}

QSpinBox::up-arrow, QDoubleSpinBox::up-arrow {
    image: url(UI/spin_up.svg);
}

QSpinBox::down-arrow, QDoubleSpinBox::down-arrow {
    image: url(UI/spin_down.svg);
}

QSpinBox::up-button:hover, QSpinBox::down-button:hover,
QDoubleSpinBox::up-button:hover, QDoubleSpinBox::down-button:hover {
    background-color: #4b4690;
    border-left: 1px solid #aebdff;
}

QSpinBox::up-button:pressed, QSpinBox::down-button:pressed,
QDoubleSpinBox::up-button:pressed, QDoubleSpinBox::down-button:pressed {
    background-color: #2563eb;
}

QPushButton {
    background-color: #2563eb;
    color: #ffffff;
    border: 1px solid rgba(188, 201, 242, 0.45);
    border-radius: 8px;
    padding: 6px 14px;
    min-height: 34px;
    font-size: 13px;
    font-weight: 600;
}

QPushButton:hover {
    background-color: #3b82f6;
    border: 1px solid #8cc1ff;
}

QPushButton:pressed {
    background-color: #1d4ed8;
}

QCheckBox {
    spacing: 8px;
    color: #e8ecff;
    min-height: 28px;
}

QCheckBox::indicator {
    width: 16px;
    height: 16px;
}

QCheckBox::indicator:unchecked {
    border: 1px solid #6d79a0;
    border-radius: 4px;
    background: #201f34;
}

QCheckBox::indicator:hover {
    border: 1px solid #7cb6ff;
    background: #2a2844;
}

QCheckBox::indicator:checked {
    border: 1px solid #60a5fa;
    border-radius: 4px;
    background: #2563eb;
}

QPlainTextEdit {
    background-color: #1f1d33;
    color: #f3f6ff;

    border: 1px solid rgba(140, 160, 255, 0.35);
    border-radius: 10px;

    padding: 6px 10px;
    min-height: 34px;

    selection-background-color: #4f46e5;
	scrollbar-width:0px;
	scrollbar-height:0px;
}

/* 鼠标悬停：边框变亮 */
QPlainTextEdit:hover {
    border: 1px solid rgba(180, 195, 255, 0.85);
    background-color: #23203a;
}

/* 聚焦：发光最强（核心效果） */
QPlainTextEdit:focus{
    border: 2px solid rgba(210, 220, 255, 1.0);
    background-color: #25223d;
}</string>
