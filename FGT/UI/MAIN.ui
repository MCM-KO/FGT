    border: 1px solid rgba(188, 201, 242, 0.34);
    border-radius: 12px;
}

QWidget#scrollAreaWidgetContents, QWidget#scrollAreaWidgetContents_2,
QWidget#scrollAreaWidgetContents_3, QWidget#scrollAreaWidgetContents_4,
QWidget#layoutWidget {
    background-color: #25243c;
    border: 1px solid rgba(188, 201, 242, 0.26);
    border-radius: 10px;
}

QStackedWidget#SHOW QComboBox,
QStackedWidget#SHOW QSpinBox,
QStackedWidget#SHOW QDoubleSpinBox {
    border: 1px solid rgba(188, 201, 242, 0.56);
    background-color: #211f37;
}

QStackedWidget#SHOW QSpinBox,
QStackedWidget#SHOW QDoubleSpinBox {
    min-width: 70px;
    max-width: 90px;
}

QStackedWidget#SHOW QComboBox {
    min-width: 92px;
}

QStackedWidget#SHOW QPlainTextEdit {
    min-height: 38px;
}

